$if bash
    set editing-mode vi
    set keyseq-timeout 5
    set show-mode-in-prompt on
    set vi-cmd-mode-string "\1\e[38;2;215;153;33m\2N\1\e[0m\2"
    set vi-ins-mode-string "\1\e[38;2;29;131;219m\2I\1\e[0m\2"

    set keymap vi-command
    "v": ""
    "\C-p": history-search-backward
    "\C-n": history-search-forward

    set keymap vi-insert
    "\C-p": history-search-backward
    "\C-n": history-search-forward
$endif
